		</svg>
	)
}

{
	variant === 'allah' && (
		<svg
			viewBox="0 0 200 200"
			width={s}
			height={s}
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			class={cn('text-foreground/20', className)}
