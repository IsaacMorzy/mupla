			<path d="M325 55 Q318 48 315 55 Q312 62 320 70 Q328 60 335 45" />
			<!-- ن -->
			<path d="M350 140 Q348 115 350 90 Q352 70 357 65 Q362 63 360 58 Q356 50 348 55 Q342 62 347 80" />
			<path d="M357 65 Q353 62 350 65" />
