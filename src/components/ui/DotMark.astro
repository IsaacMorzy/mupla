---
/**
 * DotMark — a tiny circular separator used between star marks
 * in the IslamicDivider star chains.
 *
 * Accepts an optional `class` for custom styling.
 */
interface Props {
	class?: string;
}

const { class: className } = Astro.props;
---

<svg
	xmlns="http://www.w3.org/2000/svg"
	viewBox="-4 -4 8 8"
	width="5"
	height="5"
	class:list={['ornament-stroke', className]}
	stroke-width="1"
>
	<circle cx="0" cy="0" r="2" />
</svg>
