}

{
	variant === 'ornament' && (
		<svg
			viewBox="0 0 200 40"
			width={s}
			height={s / 5}
			fill="none"
			stroke="currentColor"
			stroke-width="1"
			stroke-linecap="round"
			class={cn('text-foreground/15', className)}
			aria-hidden="true"
		>
			<!-- Symmetrical arabesque flourish -->
