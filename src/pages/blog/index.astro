---
import { Icon } from 'astro-icon/components';
import Base from '../../layouts/Base.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Badge from '../../components/ui/Badge.astro';
import Button from '../../components/ui/Button.astro';
import Input from '../../components/ui/Input.astro';
import Label from '../../components/ui/Label.astro';
import IslamicDivider from '../../components/ui/IslamicDivider.astro';
import { getConfig, listBlogs } from '../../lib/data';
import type { CmsBlog } from '../../lib/data';

const posts: CmsBlog[] = await listBlogs();
const config = (await getConfig()).data?.config ?? null;

// Fall back to "Community" when an older post has no category, and to a
// shared "author" label when none is set - keeps the visual grid uniform
// without forcing editors to fill the new fields on every legacy post.
const FALLBACK_CATEGORY = 'Community';
const FALLBACK_AUTHOR = 'mupla community';

const enriched = posts.map((post) => ({
	...post,
	_displayCategory: ((post as any).category as string | null | undefined) || FALLBACK_CATEGORY,
	_displayAuthor: ((post as any).author as string | null | undefined) || FALLBACK_AUTHOR,
}));

// Derive the category list from the posts themselves - editors control
// categories by setting the field in TinaCMS; this just reflects reality.
const categoryCounts = enriched.reduce<Record<string, number>>((acc, p) => {
	acc[p._displayCategory] = (acc[p._displayCategory] ?? 0) + 1;
	return acc;
}, {});
const categories = Object.entries(categoryCounts).sort(([, a], [, b]) => b - a);

const featured = enriched[0] ?? null;
const rest = enriched.slice(1);
---

<Base
	title={`Blog${config?.seo?.title ? ` · ${config.seo.title}` : ''}`}
	description={config?.seo?.description ?? 'Stories, reflections, and program updates from the mupla foundation.'}
>
	<main id="main-content" class="mx-auto max-w-7xl px-6 pb-20 pt-12">
		<!-- Hero: editorial-style header with generous whitespace -->
		<header class="reveal mx-auto max-w-3xl text-center">
			<h1 class="text-balance text-5xl font-medium tracking-[-0.005em] md:text-6xl">
				Stories that shape our work
			</h1>
			<p class="mx-auto mt-6 max-w-xl text-balance text-muted-foreground leading-relaxed">
				Reflections from programs, voices from the neighborhood, and honest notes on what we are learning. Written by the people who show up.
			</p>
		</header>

		<!-- Featured post: asymmetric split with warm surface tinting -->
		{featured && (
			<section class="reveal mt-12 md:mt-16">
				<a
					href={`/blog/${featured._sys.filename}/`}
					class="group block overflow-hidden rounded-xl border border-border/60 bg-card transition-colors hover:bg-accent/20"
				>
					<div class="grid md:grid-cols-[1.3fr_1fr]">
						{featured.heroImage && (
							<div class="aspect-[4/3] overflow-hidden md:aspect-auto md:h-full">
								<img
									src={featured.heroImage}
									alt={featured.title ?? ''}
									width="1020"
									height="680"
									loading="eager"
									fetchpriority="high"
									class="size-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
								/>
							</div>
						)}
						<div class="flex flex-col justify-center gap-5 p-8 md:p-10 lg:p-12">
							<div class="flex flex-wrap items-center gap-2.5">
								<Badge variant="default">{featured._displayCategory}</Badge>
								<span class="text-xs font-medium uppercase tracking-wider text-muted-foreground">Featured</span>
							</div>
							<h2 class="text-balance text-2xl font-medium leading-tight transition-colors group-hover:text-primary md:text-3xl">
								{featured.title}
							</h2>
							{featured.description && (
								<p class="text-base leading-relaxed text-muted-foreground">{featured.description}</p>
							)}
							<div class="flex flex-wrap items-center gap-3 text-sm text-muted-foreground">
								{featured.pubDate && <FormattedDate date={new Date(featured.pubDate)} />}
								<span class="text-foreground/60">·</span>
								<span>{featured._displayAuthor}</span>
							</div>
							<div class="mt-1 flex items-center gap-2 text-sm font-medium text-primary transition-colors group-hover:text-primary/80">
								Read the story
								<Icon name="tabler:arrow-right" class="size-4 transition-transform group-hover:translate-x-1" />
							</div>
						</div>
					</div>
				</a>
			</section>
		)}

		<IslamicDivider variant="single" class="max-w-4xl mx-auto mt-12" />

		<!-- Category filter: clean pill-style navigation -->
		{categories.length > 1 && (
			<nav class="mt-10 flex flex-wrap items-center gap-2 md:mt-14" aria-label="Filter posts by category">
				<button
					type="button"
					data-category-filter=""
					aria-pressed="true"
					class="inline-flex items-center rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-all hover:bg-accent focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 [&[aria-pressed=true]]:bg-primary [&[aria-pressed=true]]:text-primary-foreground"
				>
					All stories <span class="ml-2 text-xs opacity-70">{enriched.length}</span>
				</button>
				{categories.map(([name, count]) => (
					<button
						type="button"
						data-category-filter={name}
						aria-pressed="false"
						class="inline-flex items-center rounded-full border border-border bg-background px-4 py-2 text-sm font-medium text-foreground transition-all hover:bg-accent focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 [&[aria-pressed=true]]:bg-primary [&[aria-pressed=true]]:text-primary-foreground"
					>
						{name} <span class="ml-2 text-xs opacity-70">{count}</span>
					</button>
				))}
			</nav>
		)}

		<!-- Post grid: refined cards with better hierarchy -->
		{rest.length > 0 ? (
			<ul
				id="post-grid"
				class="mt-8 grid list-none gap-6 p-0 md:grid-cols-2 md:gap-8 lg:grid-cols-3"
			>
				{rest.map((post, i) => (
					<li data-category={post._displayCategory} style={`--reveal-i: ${i}`}>
						<a
							href={`/blog/${post._sys.filename}/`}
							class="group flex h-full flex-col overflow-hidden rounded-xl border border-border/60 bg-card transition-all duration-300 hover:border-border hover:bg-accent/20"
						>
							{post.heroImage && (
								<div class="aspect-[16/10] overflow-hidden">
									<img
										src={post.heroImage}
										alt={post.title ?? ''}
										width="720"
										height="450"
										loading="lazy"
										class="size-full object-cover transition-transform duration-700 group-hover:scale-[1.02]"
									/>
								</div>
							)}
							<div class="flex flex-1 flex-col gap-3 p-6">
								<div class="flex flex-wrap items-center gap-2">
									<Badge variant="outline">{post._displayCategory}</Badge>
									{post.pubDate && (
										<time datetime={post.pubDate} class="text-xs text-muted-foreground">
											<FormattedDate date={new Date(post.pubDate)} />
										</time>
									)}
								</div>
								<h3 class="text-balance text-lg font-medium leading-snug transition-colors group-hover:text-primary">
									{post.title}
								</h3>
								{post.description && (
									<p class="line-clamp-3 text-sm leading-relaxed text-muted-foreground">{post.description}</p>
								)}
								<div class="mt-auto flex items-center justify-between gap-2 pt-4 text-sm">
									<span class="text-muted-foreground">{post._displayAuthor}</span>
									<span class="inline-flex items-center gap-1 font-medium text-primary transition-colors">
										Read
										<Icon name="tabler:arrow-right" class="size-4 transition-transform group-hover:translate-x-1" />
									</span>
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>
		) : (
			<p class="mt-12 text-center text-muted-foreground">No more posts yet — check back soon.</p>
		)}

		<!-- Newsletter signup: clean, editorial-style CTA -->
		<section class="reveal mt-20 md:mt-24">
			<div class="mx-auto grid max-w-4xl items-center gap-8 rounded-2xl border border-border/60 bg-secondary/50 px-8 py-10 md:grid-cols-[1.5fr_1fr] md:px-12 md:py-14">
				<div>
					<h2 class="text-balance text-2xl font-medium leading-tight md:text-3xl">
						Stay in the loop
					</h2>
					<p class="mt-3 text-muted-foreground leading-relaxed">
						One email a month with what we are learning, what is working, and how your support moves the work forward.
					</p>
				</div>
				<form
					class="flex flex-col gap-3 sm:flex-row"
					data-newsletter
					data-action=""
					data-success="Thanks! Check your inbox to confirm your subscription."
					data-error="Something went wrong. Please try again or email us directly."
					novalidate
				>
					<div class="grid flex-1 gap-1.5">
						<Label for={`newsletter-blog`} class="sr-only">Email address</Label>
						<Input
							id={`newsletter-blog`}
							name="email"
							type="email"
							required
							placeholder="you@example.com"
						/>
					</div>
					<Button type="submit" size="lg">
						Subscribe
					</Button>
				</form>
			</div>
		</section>
	</main>
</Base>

<script>
	// Lightweight client-side category filtering. Editors derive categories
	// from each post in the CMS; this just toggles which cards are visible.
	const buttons = document.querySelectorAll<HTMLButtonElement>('[data-category-filter]');
	const cards = document.querySelectorAll<HTMLLIElement>('#post-grid > li');

	if (buttons.length > 0 && cards.length > 0) {
		const applyFilter = (filter: string) => {
			let visibleCount = 0;
			cards.forEach((li) => {
				const matches = filter === '' || li.dataset.category === filter;
				li.style.display = matches ? '' : 'none';
				if (matches) visibleCount += 1;
			});
			// Reflect the current filter on the URL hash so deep-links and
			// back/forward navigation preserve the selected category.
			const hash = filter ? `#category=${encodeURIComponent(filter)}` : '';
			if (location.hash !== hash) {
				history.replaceState(null, '', hash || location.pathname + location.search);
			}
		};
		const setActive = (target: string) => {
			buttons.forEach((b) => {
				const isActive = (b.dataset.categoryFilter ?? '') === target;
				b.setAttribute('aria-pressed', isActive ? 'true' : 'false');
			});
		};
		const targetFromHash = (): string => {
			const m = location.hash.match(/^#category=(.+)$/);
			return m ? decodeURIComponent(m[1]) : '';
		};
		// Honor the URL on first paint so deep-links work without JS round-trips.
		const initial = targetFromHash();
		if (initial) {
			setActive(initial);
			applyFilter(initial);
		}
		buttons.forEach((btn) => {
			btn.addEventListener('click', () => {
				const filter = btn.dataset.categoryFilter ?? '';
				setActive(filter);
				applyFilter(filter);
			});
		});
	}
</script>
