---
import type { HTMLAttributes } from 'astro/types';
import { cn } from '../../lib/cn';

type Props = HTMLAttributes<'textarea'>;

const { class: className, ...rest } = Astro.props;
---
<textarea
	class={cn(
		'flex min-h-[80px] w-full rounded-lg border border-input bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-[3px] focus-visible:ring-ring/50 disabled:cursor-not-allowed disabled:opacity-50',
		className
	)}
	{...rest}
></textarea>
