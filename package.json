{
  "name": "mupla-front",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.22.0"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=3072' tinacms dev -c \"astro dev\"",
    "build": "NODE_OPTIONS='--max-old-space-size=3072' tinacms build --content=local && NODE_OPTIONS='--max-old-space-size=2048' astro build",
    "build:local": "NODE_OPTIONS='--max-old-space-size=3072' tinacms build --local --skip-cloud-checks && NODE_OPTIONS='--max-old-space-size=3072' astro build",
    "build:search": "NODE_OPTIONS='--max-old-space-size=3072' tinacms search-index",
    "preview": "astro preview",
    "astro": "astro",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.7.0",
    "@astrojs/mdx": "^6.0.2",
    "@astrojs/netlify": "^7.0.13",
    "@astrojs/node": "^10.1.4",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/vercel": "^10.0.8",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/noto-naskh-arabic": "^5.2.11",
    "@iconify-json/tabler": "^1.2.35",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tinacms/astro": "^0.5.0",
    "astro": "^6.4.4",
    "astro-icon": "^1.1.5",
    "clsx": "^2.1.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@tinacms/cli": "^2.4.4",
    "@tsconfig/node18": "^18.2.6",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tinacms": "^3.9.1",
    "typescript": "^6.0.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.10"
  }
}