---
/**
 * GeometricDivider - a quiet horizontal ornament between page sections.
 *
 * Uses a centered row of three repeating marks: 8-point mark, small
 * circle, 8-point mark. Between two faint hairlines. The mark chain
 * matches the visual rhythm of manuscript dividers - same vocabulary as
 * the GeometricMedallion, only stretched horizontal and sighted.
 *
 * Honors prefers-reduced-motion through the same keyframe gate in
 * global.css (`.animate-breathe` becomes static).
 */
interface Props {
	class?: string;
	label?: string;
	decorative?: boolean;
}

const { class: className, label = 'Section divider', decorative = true } = Astro.props;
const rootProps: Record<string, unknown> = decorative
	? { 'aria-hidden': true, focusable: false }
	: { role: 'img', 'aria-label': label, focusable: false };
---

<div class:list={['flex w-full items-center justify-center gap-4 py-6', className]} {...rootProps}>
	<span class='h-px flex-1 bg-border/60'></span>
	<svg
		xmlns='http://www.w3.org/2000/svg'
		viewBox='-12 -12 24 24'
		width='24'
		height='24'
		class='ornament-stroke animate-breathe'
		stroke-width='1'
		stroke-linecap='round'
		stroke-linejoin='round'
	>
		<rect x='-8' y='-8' width='16' height='16' />
		<rect x='-8' y='-8' width='16' height='16' transform='rotate(45)' />
	</svg>
	<svg
		xmlns='http://www.w3.org/2000/svg'
		viewBox='-4 -4 8 8'
		width='8'
		height='8'
		class='ornament-stroke'
		stroke-width='1'
		stroke-linecap='round'
	>
		<circle cx='0' cy='0' r='2.5' />
	</svg>
	<svg
		xmlns='http://www.w3.org/2000/svg'
		viewBox='-12 -12 24 24'
		width='24'
		height='24'
		class='ornament-stroke animate-breathe'
		stroke-width='1'
		stroke-linecap='round'
		stroke-linejoin='round'
	>
		<rect x='-8' y='-8' width='16' height='16' />
		<rect x='-8' y='-8' width='16' height='16' transform='rotate(45)' />
	</svg>
	<span class='h-px flex-1 bg-border/60'></span>
</div>
