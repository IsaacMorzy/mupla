---
import Base from '../layouts/Base.astro';
import Button from '../components/ui/Button.astro';
import OrbitRings from '../components/space/OrbitRings.astro';
---
<Base title="Page not found (404)" description="The page you're looking for doesn't exist or has moved.">
	<section class="relative flex min-h-[70vh] items-center justify-center overflow-hidden px-6 text-center">
		<OrbitRings class="opacity-60" />
		<div class="relative flex flex-col items-center">
			<p class="text-sm font-medium tracking-widest text-primary uppercase">Error 404</p>
			<h1 class="mt-2 text-4xl font-semibold tracking-tight lg:text-5xl">This page drifted away</h1>
			<p class="mx-auto mt-4 max-w-md text-muted-foreground">
				We couldn't find what you were looking for. The page may have moved, or the link might be a little worn. Let's get you back to familiar ground.
			</p>
			<div class="mt-8 flex flex-wrap justify-center gap-3">
				<Button href="/">Back to home</Button>
				<Button href="/get-involved" variant="outline">Get involved</Button>
			</div>
		</div>
	</section>
</Base>
