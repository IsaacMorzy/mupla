---
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import { tinaField } from '@tinacms/astro/tina-field';
import GeometricMedallion from '../ui/GeometricMedallion.astro';
import type { CtaBlock } from '../../lib/data';

interface Props { data: CtaBlock }

const { data } = Astro.props;
const actions = (data.actions ?? []).filter(a => a !== null);
const headingId = (data.title ?? '').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '') || undefined;
---

<Section class="relative overflow-hidden">
	<!-- Twin geometric ornaments act as a manuscript frame. Slightly
	     larger and more saturated than Stats medallions because this is
	     the closer; this is the visual that ends the page semantically. -->
	<div aria-hidden="true" class="pointer-events-none absolute -right-20 top-8 hidden md:block">
		<GeometricMedallion
			size={260}
			weight="thin"
			variant="twin"
			class="opacity-20 animate-spin-slower"
		/>
	</div>
	<div aria-hidden="true" class="pointer-events-none absolute -left-20 bottom-8 hidden md:block">
		<GeometricMedallion
			size={260}
			weight="thin"
			variant="solo"
			class="opacity-20 animate-spin-slow"
		/>
	</div>
	<div class="reveal relative text-center">
		<h2 id={headingId} class="text-balance text-4xl font-medium tracking-[-0.005em] lg:text-5xl" data-tina-field={tinaField(data, 'title')}>{data.title}</h2>
		<p class="mx-auto mt-4 max-w-2xl text-balance text-muted-foreground" data-tina-field={tinaField(data, 'description')}>{data.description}</p>			<div class="reveal-stagger mt-12 flex flex-wrap justify-center gap-4" role="region" aria-live="polite" aria-label={data.title ?? 'Call to action'}>
			{actions.map((action, i) => (
				<div
					class="reveal"
					data-tina-field={tinaField(action)}
					style={`--reveal-i: ${i}`}
				>
					<Button href={action.link} size="lg" variant={action.type === 'link' ? 'ghost' : 'default'} class="rounded-xl px-5 text-base" {...(action.tier ? { 'data-tier': action.tier } : {})}>
						{action.icon && <Icon name={action.icon} class="size-4" />}
						<span class="text-nowrap">{action.label}</span>
					</Button>
				</div>
			))}
		</div>
	</div>
</Section>
