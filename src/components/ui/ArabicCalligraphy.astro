			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			class={cn('text-foreground/20', className)}
			aria-hidden="true"
		>
			<!-- م -->
			<path d="M20 155 Q25 125 22 95 Q20 70 25 50 Q28 35 35 40 Q40 45 35 60 Q30 80 28 100 Q26 120 28 145" />
			<path d="M25 50 Q18 43 15 50 Q12 58 20 65 Q28 55 35 40" />
			<!-- ح -->
			<path d="M50 75 Q48 95 50 120 Q51 135 55 130 Q59 125 60 110 Q61 95 58 80" />
			<path d="M58 80 Q63 70 70 68 Q75 67 73 72 Q69 78 63 78" />
			<!-- م -->
			<path d="M85 155 Q90 125 87 95 Q85 70 90 50 Q93 35 100 40 Q105 45 100 60 Q95 80 93 100 Q91 120 93 145" />
			<path d="M90 50 Q83 43 80 50 Q77 58 85 65 Q93 55 100 40" />
			<!-- د -->
			<path d="M115 145 Q113 120 115 95 Q117 70 122 65 Q127 63 125 58 Q121 50 113 55 Q107 62 112 80 Q118 110 116 140" />
