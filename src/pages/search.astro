---
import Base from '../layouts/Base.astro';
import Input from '../components/ui/Input.astro';
import Label from '../components/ui/Label.astro';
import Icon from '../components/ui/Icon.astro';
import { getConfig } from '../lib/data';

const config = (await getConfig()).data?.config ?? null;
---
<Base
	title={`Search${config?.seo?.title ? ` — ${config.seo.title}` : ''}`}
	description="Search blog posts and events on the mupla foundation site."
>
	<main class="mx-auto max-w-3xl px-6 py-16">
		<header class="mb-10 text-center">
			<h1 class="text-balance text-4xl font-semibold tracking-tight md:text-5xl">Search</h1>
			<p class="mt-3 text-muted-foreground">Find blog posts and upcoming events across the site.</p>
		</header>

		<div class="mx-auto max-w-2xl">
			<Label for="search-input" class="sr-only">Search</Label>
			<div class="relative">
				<Icon name="search" class="pointer-events-none absolute left-3 top-1/2 size-4 -translate-y-1/2 text-muted-foreground" />
				<Input
					id="search-input"
					name="q"
					type="search"
					placeholder="Try &quot;iftar&quot;, &quot;zakat&quot;, &quot;youth&quot;…"
					autocomplete="off"
					class="pl-9"
				/>
			</div>
		</div>

		<div id="search-status" class="mx-auto mt-6 max-w-2xl text-sm text-muted-foreground" aria-live="polite">
			Loading…
		</div>
		<ul id="search-results" class="mx-auto mt-4 max-w-2xl divide-y rounded-xl border bg-card"></ul>
	</main>
</Base>

<script>
	type FeedItem = {
		title: string;
		description?: string;
		pubDate?: string;
		link: string;
		category: 'blog' | 'event';
	};

	const results = document.getElementById('search-results') as HTMLUListElement | null;
	const status = document.getElementById('search-status') as HTMLDivElement | null;
	const input = document.getElementById('search-input') as HTMLInputElement | null;

	if (results && status && input) {
		const esc = (s: string): string =>
			s.replace(/[&<>"']/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] ?? c));
		const highlight = (text: string, query: string): string => {
			if (!query) return esc(text);
			const safe = esc(text);
			const safeQuery = esc(query).replace(/[.*+?^${}()|[\]\\]/g, '\\$&');
			return safe.replace(new RegExp(safeQuery, 'gi'), (m) => `<mark class="bg-primary/15 text-foreground rounded px-0.5">${m}</mark>`);
		};

		const render = (items: FeedItem[], query: string): void => {
			results!.innerHTML = '';
			if (!query) {
				status!.textContent = 'Type to search blog posts and events.';
				return;
			}
			if (items.length === 0) {
				status!.textContent = `No matches for "${query}".`;
				return;
			}
			status!.textContent = `${items.length} ${items.length === 1 ? 'result' : 'results'} for "${query}".`;
			const frag = document.createDocumentFragment();
			for (const item of items) {
				const li = document.createElement('li');
				li.className = 'p-5';
				li.innerHTML = `
					<a href="${esc(item.link)}" class="group block">
						<div class="flex items-center gap-2 text-xs uppercase tracking-wide text-muted-foreground">
							<span class="rounded-full bg-muted px-2 py-0.5">${esc(item.category)}</span>
							${item.pubDate ? `<time datetime="${esc(item.pubDate)}">${esc(new Date(item.pubDate).toLocaleDateString())}</time>` : ''}
						</div>
						<h2 class="mt-1 font-medium group-hover:underline">${highlight(item.title, query)}</h2>
						${item.description ? `<p class="mt-1 line-clamp-2 text-sm text-muted-foreground">${highlight(item.description, query)}</p>` : ''}
					</a>
				`;
				frag.appendChild(li);
			}
			results!.appendChild(frag);
		};

		const search = (items: FeedItem[], query: string): FeedItem[] => {
			const q = query.trim().toLowerCase();
			if (!q) return [];
			return items
				.filter((item) =>
					item.title.toLowerCase().includes(q) ||
					(item.description ?? '').toLowerCase().includes(q),
				)
				.slice(0, 30);
		};

		let items: FeedItem[] = [];
		fetch('/rss.xml')
			.then((r) => r.text())
			.then((xml) => {
				const doc = new DOMParser().parseFromString(xml, 'application/xml');
				const nodes = Array.from(doc.querySelectorAll('item'));
				items = nodes.map((node) => {
					const link = node.querySelector('link')?.textContent ?? '';
					const title = node.querySelector('title')?.textContent ?? '';
					const description = node.querySelector('description')?.textContent ?? undefined;
					const pubDate = node.querySelector('pubDate')?.textContent ?? undefined;
					const category = title.startsWith('[Event]')
						? 'event'
						: link.includes('/events/')
							? 'event'
							: 'blog';
					return {
						title: title.replace(/^\[Event\]\s*/, ''),
						description,
						pubDate,
						link,
						category,
					};
				});
				status!.textContent = 'Type to search blog posts and events.';
			})
			.catch(() => {
				status!.textContent = 'Could not load the search index. Try again later.';
			});

		let timer: number | undefined;
		input.addEventListener('input', () => {
			window.clearTimeout(timer);
			timer = window.setTimeout(() => {
				render(search(items, input.value), input.value);
			}, 120);
		});
		input.focus();
	}
</script>
