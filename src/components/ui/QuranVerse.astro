---
/**
 * QuranVerse - fetches a random Quran verse with Arabic and English
 * translation from AlQuran.cloud at build time (free, no key).
 *
 * Picks a random surah (1-114) and verse, fetches both the Arabic
 * Uthmani script and Muhammad Asad's English translation, then renders
 * them as a centred blockquote with citation.
 */
import Section from './Section.astro';

interface AlQuranSurah {
	number: number;
	name: string;
	englishName: string;
	englishNameTranslation: string;
	numberOfAyahs: number;
	revelationType: string;
}

let arabicText = '';
let englishText = '';
let surahName = '';
let verseNumber = 0;

try {
	// Fetch surah list, pick one randomly, then pick a random verse
	const surahsRes = await fetch('https://api.alquran.cloud/v1/surah');
	if (surahsRes.ok) {
		const json = await surahsRes.json();
		const surahs: AlQuranSurah[] = json.data ?? [];
		const surah = surahs[Math.floor(Math.random() * surahs.length)];
		if (surah) {
			const ayahNum = Math.floor(Math.random() * surah.numberOfAyahs) + 1;
			surahName = surah.englishName;
			verseNumber = ayahNum;

			// Fetch Arabic Uthmani + English Asad in parallel
			const [arabicRes, englishRes] = await Promise.all([
				fetch(`https://api.alquran.cloud/v1/ayah/${surah.number}:${ayahNum}/quran-uthmani`),
				fetch(`https://api.alquran.cloud/v1/ayah/${surah.number}:${ayahNum}/en.asad`),
			]);

			if (arabicRes.ok) {
				const a = await arabicRes.json();
				arabicText = a.data?.text ?? '';
			}
			if (englishRes.ok) {
				const e = await englishRes.json();
				englishText = e.data?.text ?? '';
			}
		}
	}
} catch {
	// Silently fall back — section renders nothing if fetch fails.
}

const hasVerse = Boolean(arabicText && englishText);
---

{hasVerse && (
	<Section class="relative overflow-hidden">
		<div class="reveal mx-auto max-w-3xl px-6 text-center">
			<blockquote cite={`https://quran.com/${surahName.toLowerCase().replace(/\s+/g, '-')}/${verseNumber}`} class="mt-6">
				<p lang="ar" dir="rtl" class="font-calligraphy text-3xl leading-[1.8] text-foreground md:text-4xl lg:text-5xl">
					{arabicText}
				</p>
				<p class="mx-auto mt-6 max-w-2xl text-balance italic leading-relaxed text-muted-foreground">
					{englishText}
				</p>
			</blockquote>
			<footer class="mt-6">
				<cite class="text-sm not-italic text-muted-foreground">
					Surah {surahName}, verse {verseNumber}
				</cite>
			</footer>
		</div>
	</Section>
)}
