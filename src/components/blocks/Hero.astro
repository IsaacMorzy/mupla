---
import { tinaField } from '@tinacms/astro/tina-field';
import Section from '../ui/Section.astro';
import Button from '../ui/Button.astro';
import Icon from '../ui/Icon.astro';
import GeometricMedallion from '../ui/GeometricMedallion.astro';
import type { HeroBlock } from '../../lib/data';

interface Props { data: HeroBlock }

const { data } = Astro.props;
const actions = (data.actions ?? []).filter(a => a !== null);
---

<Section class="relative overflow-hidden bg-default">
	<!-- Decorative geometric ornament: slow-rotating eight-pointed star
	     receding into the upper-right corner. Sized at 24vw clamped to a
	     maximum so it stays proportional at every breakpoint, with a
	     minimum so the lines render crisply on small screens. The class
	     honours prefers-reduced-motion through the keyframe gate in
	     global.css (animation: none in reduce mode).
	     
	     Twin medallions create a manuscript-frame effect: clockwise in
	     the upper-right, counter-clockwise in the lower-left. -->
	<div aria-hidden="true" class="pointer-events-none absolute -right-24 -top-24 hidden md:block">
		<GeometricMedallion
			size={420}
			weight="thin"
			variant="solo"
			class="opacity-[0.18] animate-spin-slower"
		/>
	</div>
	<div aria-hidden="true" class="pointer-events-none absolute -bottom-32 -left-24 hidden md:block">
		<GeometricMedallion
			size={340}
			weight="thin"
			variant="solo"
			class="opacity-[0.10] animate-spin-slow"
		/>
	</div>

	<div class="reveal relative text-center sm:mx-auto lg:mr-auto">
		<div data-tina-field={tinaField(data, 'image')} class="mx-auto mb-6 size-56 md:size-72">
			{data.image?.src
				? <img src={data.image.src} alt={data.image.alt ?? ''} width="224" height="224" fetchpriority="high" loading="eager" decoding="async" class="size-full rounded-full object-cover" />
				: ''}
		</div>
		{data.headline && <h1 data-tina-field={tinaField(data, 'headline')} class="text-balance text-5xl md:text-6xl xl:text-7xl font-semibold leading-[1.05] tracking-tight">{data.headline}</h1>}
		{data.tagline && <p data-tina-field={tinaField(data, 'tagline')} class="mx-auto mt-6 max-w-2xl text-balance text-base text-muted-foreground md:text-lg">{data.tagline}</p>}
		{actions.length > 0 && (
			<div class="reveal-stagger mt-10 flex flex-col items-center justify-center gap-2 md:flex-row">
				{actions.map((action, i) => (
					<div
						data-tina-field={tinaField(action)}
						class="reveal"
						style={`--reveal-i: ${i}`}
					>
						<Button href={action.link} size="lg" variant={action.type === 'link' ? 'outline' : 'default'} class="rounded-xl px-5 text-base">
							{action.icon && <Icon name={action.icon} class="size-4" />}
							<span class="text-nowrap">{action.label}</span>
						</Button>
					</div>
				))}
			</div>
		)}
	</div>
</Section>
