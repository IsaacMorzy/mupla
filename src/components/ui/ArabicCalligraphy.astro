---
/**
 * ArabicCalligraphy — decorative Arabic calligraphy flourishes.
 * Renders culturally-resonant SVG calligraphy (Bismillah + ornamental
 * arabesque lines). Use as a section opener, page divider, or decorative
 * accent. All paths are hand-traced approximations of classical
 * Thuluth calligraphy strokes.
 *
 * @prop variant - "bismillah" (full Bismillah), "ornament" (flourish strokes)
 * @prop size - pixel size for the SVG viewport (default 400 for bismillah, 200 for ornament)
 * @prop class - additional Tailwind classes
 */
import { cn } from '../../lib/cn';

interface Props {
	variant?: 'bismillah' | 'ornament' | 'allah' | 'muhammad';
	size?: number;
	class?: string;
}

const { variant = 'bismillah', size, class: className } = Astro.props;
const s = size ?? (variant === 'bismillah' ? 600 : 200);
---

{
	variant === 'bismillah' && (
		<svg
			viewBox="0 0 600 200"
			width={s}
			height={s / 3}
			fill="none"
			stroke="currentColor"
			stroke-width="1.5"
			stroke-linecap="round"
			stroke-linejoin="round"
			class={cn('text-foreground/30', className)}
			aria-hidden="true"
		>
			<!-- Bismillah in simplified Thuluth-like strokes -->
			<!-- ب -->
			<path d="M20 100 Q30 60 25 40 Q22 30 18 35 Q14 42 20 55 Q25 72 20 100 Q18 118 22 135 Q28 155 35 150" />
			<path d="M18 35 Q15 28 12 32" />
			<!-- س -->
			<path d="M45 140 Q50 120 48 100 Q47 85 50 70 Q53 55 58 60 Q63 65 60 80 Q56 98 55 115 Q54 130 56 145" />
			<path d="M50 70 Q60 50 68 45 Q75 42 72 48 Q68 55 62 60" />
