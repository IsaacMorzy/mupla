---
import type { HTMLAttributes } from 'astro/types';
import { tv, type VariantProps } from 'tailwind-variants';
import { cn } from '../../lib/cn';

const badge = tv({
	base: 'inline-flex items-center rounded-full border px-2.5 py-0.5 text-xs font-semibold transition-colors focus:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 focus-visible:ring-offset-background',
	variants: {
		variant: {
			default: 'border-transparent bg-primary text-primary-foreground hover:bg-primary/80',
			secondary: 'border-transparent bg-secondary text-secondary-foreground hover:bg-secondary/80',
			destructive: 'border-transparent bg-destructive text-white hover:bg-destructive/80',
			outline: 'text-foreground border-border',
		},
	},
	defaultVariants: { variant: 'default' },
});

type Props = HTMLAttributes<'span'> & VariantProps<typeof badge>;

const { variant, class: className, ...rest } = Astro.props;
const classes = cn(badge({ variant }), className);
---
<span class={classes} {...rest}><slot /></span>
