---
import Base from '../layouts/Base.astro';
import Section from '../components/ui/Section.astro';
import IslamicDivider from '../components/ui/IslamicDivider.astro';
import Icon from '../components/ui/Icon.astro';
import ArabicCalligraphy from '../components/ui/ArabicCalligraphy.astro';
import GeometricMedallion from '../components/ui/GeometricMedallion.astro';
import { getConfig } from '../lib/data';

const config = (await getConfig()).data?.config ?? null;

// ── Fetch Quranic supplications from AlQuran.cloud (free, no key) ──
const supplicationDefs = [
	{ surah: 2, ayah: 201, ref: 'Surah Al-Baqarah, verse 201', arabic: 'رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ', english: 'Our Lord, grant us good in this world and good in the Hereafter, and protect us from the punishment of the Fire.' },
	{ surah: 3, ayah: 8,   ref: 'Surah Aal-e-Imran, verse 8', arabic: 'رَبَّنَا لَا تُزِغْ قُلُوبَنَا بَعْدَ إِذْ هَدَيْتَنَا وَهَبْ لَنَا مِن لَّدُنكَ رَحْمَةً إِنَّكَ أَنتَ الْوَهَّابُ', english: 'Our Lord, let not our hearts deviate after You have guided us, and grant us from Yourself mercy. Indeed, You are the Bestower.' },
	{ surah: 59, ayah: 10, ref: 'Surah Al-Hashr, verse 10', arabic: 'رَبَّنَا اغْفِرْ لَنَا وَلِإِخْوَانِنَا الَّذِينَ سَبَقُونَا بِالْإِيمَانِ', english: 'Our Lord, forgive us and our brothers who preceded us in faith.' },
];

const displaySupplications = await Promise.all(supplicationDefs.map(async (def) => {
	try {
		const [arabicRes, englishRes] = await Promise.all([
			fetch(`https://api.alquran.cloud/v1/ayah/${def.surah}:${def.ayah}/quran-uthmani`),
			fetch(`https://api.alquran.cloud/v1/ayah/${def.surah}:${def.ayah}/en.asad`),
		]);
		if (arabicRes.ok && englishRes.ok) {
			const [arabicJson, englishJson] = await Promise.all([arabicRes.json(), englishRes.json()]);
			return {
				arabic: (arabicJson as any).data?.text || def.arabic,
				english: (englishJson as any).data?.text || def.english,
				ref: def.ref,
			};
		}
	} catch { /* fall through to hardcoded */ }
	return { arabic: def.arabic, english: def.english, ref: def.ref };
}));

// ── Fetch 3 random duas from UmmahAPI at build time ──
// Fetch 3 random duas from UmmahAPI in parallel
const duas: { arabic: string; translation: string; title: string; category: string }[] = [];
const duaResults = await Promise.allSettled(
	Array.from({ length: 3 }, () => fetch('https://ummahapi.com/api/duas/random'))
);
for (const result of duaResults) {
	if (result.status === 'fulfilled' && result.value.ok) {
		try {
			const json = await result.value.json();
			if (json.success && json.data) {
				duas.push({
					arabic: json.data.arabic || '',
					translation: json.data.translation || json.data.transliteration || '',
					title: json.data.title || 'Dua',
					category: json.data.category || '',
				});
			}
		} catch { /* skip */ }
	}
}

// ── Fetch a random hadith from UmmahAPI at build time ──
let hadith: { text: string; source: string; narrator: string } | null = null;
try {
	const res = await fetch('https://ummahapi.com/api/hadith/random');
	if (res.ok) {
		const json = await res.json();
		if (json.success && json.data) {
			hadith = {
				text: json.data.english || json.data.text || '',
				source: json.data.collection_name || json.data.collection || '',
				narrator: json.data.narrator || json.data.grade || '',
			};
		}
	}
} catch { /* skip failed fetch */ }
---

<Base
	title={`Prayer times | ${config?.seo?.title ?? 'mupla Foundation'}`}
	description="Daily prayer times, duas, hadith, and Quranic supplications for the Muslim community."
>
	<main id="main-content" class="mx-auto max-w-5xl px-6 py-12">
		<header class="reveal mx-auto max-w-2xl text-center">
			<h1 class="text-balance text-5xl font-medium tracking-[-0.005em] md:text-6xl">Prayer times</h1>
			<div class="mt-6 reveal-calligraphy" aria-hidden="true">
				<ArabicCalligraphy variant="bismillah" class="mx-auto block" size={400} />
			</div>
			<p class="mx-auto mt-5 max-w-xl text-balance text-muted-foreground leading-relaxed">
				Daily prayer times, selected duas, and a hadith to carry through your day, all from UmmahAPI and the Quran.
			</p>
		</header>

		<IslamicDivider variant="single" class="max-w-4xl mx-auto mt-12 mb-8" />

		<!-- Prayer times: loaded client-side from UmmahAPI -->
		<Section class="relative overflow-hidden" background="bg-secondary">
			<div aria-hidden="true" class="pointer-events-none absolute -right-16 top-0 hidden md:block animate-hilal">
				<GeometricMedallion size={180} weight="thin" variant="twin" class="opacity-[0.10] animate-spin-slower" />
			</div>
			<div class="reveal relative z-10 mx-auto max-w-3xl">
				<h2 class="text-balance text-3xl font-medium tracking-[-0.005em] md:text-4xl text-center">Today's prayer times</h2>
				<p id="prayer-date" class="mt-3 text-center text-muted-foreground">Loading...</p>
				<div id="prayer-times" class="mt-8 grid gap-3 sm:grid-cols-3 md:grid-cols-6" aria-live="polite">
					<!-- Populated by client JS from UmmahAPI -->
				</div>
				<p class="mt-6 text-center text-xs text-muted-foreground">
					Times from UmmahAPI (Muslim World League method). For accurate local times, allow location access or use a mosque timetable.
				</p>
			</div>
		</Section>

		<IslamicDivider variant="arch" class="max-w-4xl mx-auto" />

		<!-- Daily Hadith from UmmahAPI -->
		{hadith && (
			<>
			<Section>
				<div class="reveal mx-auto max-w-3xl">
					<h2 class="text-balance text-3xl font-medium tracking-[-0.005em] md:text-4xl text-center">Hadith of the day</h2>
					<p class="mt-4 text-center text-muted-foreground">
						A saying of the Prophet Muhammad, peace be upon him, refreshed each build.
					</p>
					<div class="mt-10 rounded-xl border border-border/60 bg-card p-6 md:p-8">
						<blockquote class="space-y-4">
							<p class="italic leading-relaxed text-foreground">
								{hadith.text}
							</p>
						</blockquote>
						<footer class="mt-4 flex flex-wrap items-center gap-2 text-xs text-muted-foreground">
							{hadith.narrator && <span class="font-medium text-foreground">{hadith.narrator}</span>}
							{hadith.source && <span>, {hadith.source}</span>}
						</footer>
					</div>
				</div>
			</Section>
			<IslamicDivider variant="single" class="max-w-4xl mx-auto" />
			</>
		)}

		<!-- Duas from UmmahAPI -->
		{duas.length > 0 && (
			<>
			<Section background="bg-secondary">
				<div class="reveal mx-auto max-w-3xl">
					<h2 class="text-balance text-3xl font-medium tracking-[-0.005em] md:text-4xl text-center">Selected duas</h2>
					<p class="mt-4 text-center text-muted-foreground">
						Authentic supplications from the Sunnah, fetched from UmmahAPI. Refreshed with each build.
					</p>
					<div class="mt-10 space-y-8">
						{duas.map((d) => (
						<div class="rounded-xl border border-border/60 bg-card p-6 md:p-8">
							<blockquote class="space-y-4">
								<p lang="ar" dir="rtl" class="font-serif text-2xl leading-[1.8] text-foreground md:text-3xl">{d.arabic}</p>
								<p class="italic leading-relaxed text-muted-foreground">{d.translation}</p>
							</blockquote>
							<footer class="mt-4 flex items-center gap-2 text-xs text-muted-foreground">
								<span class="font-medium text-foreground">{d.title}</span>
								{d.category && <span>· {d.category}</span>}
							</footer>
						</div>
						))}
					</div>
				</div>
			</Section>
			<IslamicDivider variant="single" class="max-w-4xl mx-auto" />
			</>
		)}

		<!-- Morning duas (curated, hardcoded from authentic sources) -->
		<Section>
			<div class="reveal mx-auto max-w-3xl">
				<h2 class="text-balance text-3xl font-medium tracking-[-0.005em] md:text-4xl text-center">Morning remembrances</h2>
				<p class="mt-4 text-center text-muted-foreground">
					Duas the Prophet Muhammad, peace be upon him, recited each morning.
				</p>

				<div class="mt-10 space-y-8">
					<div class="rounded-xl border border-border/60 bg-card p-6 md:p-8 graceful-hover">
						<blockquote class="space-y-4">
							<p lang="ar" dir="rtl" class="font-serif text-2xl leading-[1.8] text-foreground md:text-3xl">
								أَصْبَحْنَا وَأَصْبَحَ الْمُلْكُ لِلَّهِ وَالْحَمْدُ لِلَّهِ لَا إِلَٰهَ إِلَّا اللَّهُ وَحْدَهُ لَا شَرِيكَ لَهُ
							</p>
							<p class="italic leading-relaxed text-muted-foreground">
								We have entered the morning, and the entire kingdom belongs to Allah. All praise is due to Allah. There is no deity worthy of worship except Allah, alone, without any partner.
							</p>
						</blockquote>
						<footer class="mt-4 text-xs text-muted-foreground">
							Recommended to recite morning and evening
						</footer>
					</div>

					<div class="rounded-xl border border-border/60 bg-card p-6 md:p-8 graceful-hover">
						<blockquote class="space-y-4">
							<p lang="ar" dir="rtl" class="font-serif text-2xl leading-[1.8] text-foreground md:text-3xl">
								بِسْمِ اللَّهِ الَّذِي لَا يَضُرُّ مَعَ اسْمِهِ شَيْءٌ فِي الْأَرْضِ وَلَا فِي السَّمَاءِ وَهُوَ السَّمِيعُ الْعَلِيمُ
							</p>
							<p class="italic leading-relaxed text-muted-foreground">
								In the Name of Allah, with whose Name nothing can cause harm on earth or in the heavens, and He is the All-Hearing, the All-Knowing.
							</p>
						</blockquote>
						<footer class="mt-4 text-xs text-muted-foreground">
							Recite three times each morning and evening for protection
						</footer>
					</div>

					<div class="rounded-xl border border-border/60 bg-card p-6 md:p-8 graceful-hover">
						<blockquote class="space-y-4">
							<p lang="ar" dir="rtl" class="font-serif text-2xl leading-[1.8] text-foreground md:text-3xl">
								اللَّهُمَّ إِنِّي أَسْأَلُكَ عِلْمًا نَافِعًا وَرِزْقًا طَيِّبًا وَعَمَلًا مُتَقَبَّلًا
							</p>
							<p class="italic leading-relaxed text-muted-foreground">
								O Allah, I ask You for beneficial knowledge, good provision, and accepted deeds.
							</p>
						</blockquote>
						<footer class="mt-4 text-xs text-muted-foreground">
							Recommended to recite after Fajr prayer
						</footer>
					</div>
				</div>
			</div>
		</Section>

		<IslamicDivider variant="single" class="max-w-4xl mx-auto" />

		<!-- Evening duas -->
		<Section background="bg-secondary">
			<div class="reveal mx-auto max-w-3xl">
				<h2 class="text-balance text-3xl font-medium tracking-[-0.005em] md:text-4xl text-center">Evening remembrances</h2>
				<p class="mt-4 text-center text-muted-foreground">
					Duas to recite as the day closes and night approaches.
				</p>

				<div class="mt-10 space-y-8">
					<div class="rounded-xl border border-border/60 bg-card p-6 md:p-8 graceful-hover">
						<blockquote class="space-y-4">
							<p lang="ar" dir="rtl" class="font-serif text-2xl leading-[1.8] text-foreground md:text-3xl">
								أَمْسَيْنَا وَأَمْسَى الْمُلْكُ لِلَّهِ وَالْحَمْدُ لِلَّهِ لَا إِلَٰهَ إِلَّا اللَّهُ وَحْدَهُ لَا شَرِيكَ لَهُ
							</p>
							<p class="italic leading-relaxed text-muted-foreground">
								We have entered the evening, and the entire kingdom belongs to Allah. All praise is due to Allah. There is no deity worthy of worship except Allah, alone, without any partner.
							</p>
						</blockquote>
						<footer class="mt-4 text-xs text-muted-foreground">
							Recite once each evening
						</footer>
					</div>

					<div class="rounded-xl border border-border/60 bg-card p-6 md:p-8 graceful-hover">
						<blockquote class="space-y-4">
							<p lang="ar" dir="rtl" class="font-serif text-2xl leading-[1.8] text-foreground md:text-3xl">
								اللَّهُمَّ بِكَ أَمْسَيْنَا وَبِكَ أَصْبَحْنَا وَبِكَ نَحْيَا وَبِكَ نَمُوتُ وَإِلَيْكَ الْمَصِيرُ
							</p>
							<p class="italic leading-relaxed text-muted-foreground">
								O Allah, by You we enter the evening and by You we enter the morning. By You we live and by You we die, and to You is the final return.
							</p>
						</blockquote>
						<footer class="mt-4 text-xs text-muted-foreground">
							Recite once each evening
						</footer>
					</div>

					<div class="rounded-xl border border-border/60 bg-card p-6 md:p-8 graceful-hover">
						<blockquote class="space-y-4">
							<p lang="ar" dir="rtl" class="font-serif text-2xl leading-[1.8] text-foreground md:text-3xl">
								اللَّهُمَّ إِنِّي أَسْأَلُكَ الْعَافِيَةَ فِي الدُّنْيَا وَالْآخِرَةِ
							</p>
							<p class="italic leading-relaxed text-muted-foreground">
								O Allah, I ask You for well-being in this world and the Hereafter.
							</p>
						</blockquote>
						<footer class="mt-4 text-xs text-muted-foreground">
							Recommended to recite morning and evening
						</footer>
					</div>
				</div>
			</div>
		</Section>

		{displaySupplications.length > 0 && (
			<>
			<IslamicDivider variant="arch" class="max-w-4xl mx-auto" />
			<Section>
				<div class="reveal mx-auto max-w-3xl">
					<h2 class="text-balance text-3xl font-medium tracking-[-0.005em] md:text-4xl text-center">Quranic supplications</h2>
					<p class="mt-4 text-center text-muted-foreground">
						Prayers and supplications from the Quran, made by the prophets and the righteous, fetched from the Quran API.
					</p>
					<div class="mt-10 space-y-8">
						{displaySupplications.map((s) => (
						<div class="rounded-xl border border-border/60 bg-card p-6 md:p-8">
							<blockquote class="space-y-4">
								<p lang="ar" dir="rtl" class="font-serif text-2xl leading-[1.8] text-foreground md:text-3xl">{s.arabic}</p>
								<p class="italic leading-relaxed text-muted-foreground">{s.english}</p>
							</blockquote>
							<footer class="mt-4 text-xs text-muted-foreground">{s.ref}</footer>
						</div>
						))}
					</div>
				</div>
			</Section>
			</>
		)}
	</main>
</Base>

<script>
	// Fetch prayer times from UmmahAPI with a sensible default location.
	// Uses the browser's timezone for date display; Makkah calculation method.
	async function loadPrayerTimes() {
		const container = document.getElementById('prayer-times');
		const dateEl = document.getElementById('prayer-date');
		if (!container || !dateEl) return;

		try {
			// Try browser geolocation first, fall back to London
			let lat = 51.5074;
			let lng = -0.1278;
			try {
				if (navigator.geolocation) {
					const pos = await new Promise<GeolocationPosition>((resolve, reject) => {
						navigator.geolocation.getCurrentPosition(resolve, reject, {
							enableHighAccuracy: false,
							timeout: 5000,
							maximumAge: 300000,
						});
					});
					lat = pos.coords.latitude;
					lng = pos.coords.longitude;
				}
			} catch { /* use London defaults */ }

			const res = await fetch(
				`https://ummahapi.com/api/prayer-times?lat=${lat}&lng=${lng}&method=MuslimWorldLeague`
			);
			if (!res.ok) throw new Error('API error');
			const json = await res.json();
			if (!json.success) throw new Error(json.message || 'API error');

			const times = json.data.prayer_times;
			const meta = json.data;

			dateEl.textContent = `${meta.date?.readable || ''} · ${meta.calculation_method || 'Makkah method'}`;

			const prayers = [
				{ name: 'Fajr', time: times.fajr ?? '--:--', icon: 'tabler:sunrise' },
				{ name: 'Sunrise', time: times.sunrise ?? '--:--', icon: 'tabler:sun' },
				{ name: 'Dhuhr', time: times.dhuhr ?? '--:--', icon: 'tabler:sun-high' },
				{ name: 'Asr', time: times.asr ?? '--:--', icon: 'tabler:sunset' },
				{ name: 'Maghrib', time: times.maghrib ?? '--:--', icon: 'tabler:sunset-2' },
				{ name: 'Isha', time: times.isha ?? '--:--', icon: 'tabler:moon' },
			];

			container.innerHTML = prayers.map(p => `
				<div class="reveal flex flex-col items-center gap-2 rounded-xl border border-border/60 bg-card p-4 text-center graceful-hover">
					<span class="text-xs font-medium text-muted-foreground">${p.name}</span>
					<span class="font-mono text-lg font-semibold text-foreground">${p.time}</span>
				</div>
			`).join('');
		} catch {
			dateEl.textContent = 'Unable to load prayer times.';
			container.innerHTML = `<p class="col-span-full text-center text-muted-foreground">Unable to load prayer times. Please check your connection and try again.</p>`;
		}
	}

	loadPrayerTimes();
</script>
