SITE_URL=https://example.com
PUBLIC_TINA_CLIENT_ID=*** #Grab from TinaCloud app.tina.io
TINA_TOKEN=*** #Grab from TinaCloud app.tina.io

# Optional. Hosting platforms are auto-detected (Vercel, Cloudflare, Netlify → Node).
# Set this only to force an adapter for a local/manual deploy, e.g. `wrangler deploy`.
# DEPLOY_ADAPTER=cloudflare  # vercel | cloudflare | netlify | node

# Pexels API key — copy .env.example to .env and paste your key.
# See scripts/README.md for usage. Never commit .env (.gitignore covers it).
PEXELS_API_KEY=
