---
import { tinaField } from '@tinacms/astro/tina-field';
import Section from '../ui/Section.astro';
import Card from '../ui/Card.astro';
import CardContent from '../ui/CardContent.astro';
import Avatar from '../ui/Avatar.astro';
import type { TestimonialBlock, TestimonialItem } from '../../lib/data';

interface Props { data: TestimonialBlock }

const { data } = Astro.props;
const testimonials = (data.testimonials ?? []).filter(
	(t): t is TestimonialItem => t !== null,
);
const initials = (name?: string | null) => (name ?? '').split(' ').map((w) => w[0]).join('');
---

<Section>
	<div class="reveal mx-auto max-w-xl text-center">
		<h2 data-tina-field={tinaField(data, 'title')} class="text-3xl font-semibold">{data.title}</h2>
		<p data-tina-field={tinaField(data, 'description')} class="mt-4 text-muted-foreground">{data.description}</p>
	</div>
	<div class="reveal-stagger mt-10 grid gap-6 md:mt-14 sm:grid-cols-2 lg:grid-cols-3">
		{testimonials.map((t, i) => (
			<Card class="reveal card-hover h-full" data-tina-field={tinaField(t)} style={`--reveal-i: ${i}`}>
				<CardContent class="flex flex-col gap-6">
					<div aria-hidden="true" class="font-serif text-5xl leading-none text-primary/30">&ldquo;</div>
					<blockquote class="flex-1">
						<p data-tina-field={tinaField(t, 'quote')} class="text-balance text-muted-foreground leading-relaxed">{t.quote}</p>
					</blockquote>
					<div class="flex items-center gap-3 pt-4 border-t border-border/40">
						<Avatar src={t.avatar} alt={t.author} fallback={initials(t.author)} class="size-10 text-xs" />
						<div>
							<h3 data-tina-field={tinaField(t, 'author')} class="text-sm font-medium text-foreground">{t.author}</h3>
							{t.role && <p class="text-xs text-muted-foreground">{t.role}</p>}
						</div>
					</div>
				</CardContent>
			</Card>
		))}
	</div>
</Section>
