			<path d="M155 25 Q162 28 165 22 Q168 16 162 18" />
			<path d="M100 20 Q100 28 98 35" />
			<circle cx="100" cy="20" r="3" fill="currentColor" opacity="0.4" />
			<circle cx="60" cy="20" r="2" fill="currentColor" opacity="0.3" />
			<circle cx="140" cy="20" r="2" fill="currentColor" opacity="0.3" />
		</svg>
	)
}
