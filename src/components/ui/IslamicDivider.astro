---
/**
 * IslamicDivider — manuscript-inspired horizontal ornament between sections.
 *
 * Renders an 8-pointed star chain flanked by hairlines, inspired by
 * Ottoman Qur'anic illumination chapter dividers. More elaborate than
 * GeometricDivider — uses multiple mark sizes for a rhythmic,
 * manuscript-page feel.
 *
 * Variants:
 *   - 'single' — one centered star chain (default, quiet)
 *   - 'double' — two star chains stacked (for major section transitions)
 *   - 'arch' — star chain with a subtle upward arch (for headers)
 *
 * All variants use ornament-stroke for dark mode compatibility and
 * honor prefers-reduced-motion.
 */
interface Props {
	class?: string;
	variant?: 'single' | 'double' | 'arch';
	label?: string;
	decorative?: boolean;
}

const {
	class: className,
	variant = 'single',
	label = 'Section divider',
	decorative = true,
} = Astro.props;

const rootProps: Record<string, unknown> = decorative
	? { 'aria-hidden': true, focusable: false }
	: { role: 'img', 'aria-label': label, focusable: false };
---

<div class:list={['flex w-full items-center justify-center', className]} {...rootProps}>
	{
		variant === 'arch' ? (
			<div class="flex w-full flex-col items-center gap-3">
				<div class="flex w-full items-center gap-4">
					<span class="h-px flex-1 bg-border/60"></span>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="0 0 160 20"
						width="160"
						height="20"
						class="ornament-stroke animate-breathe"
						stroke-width="1"
						fill="none"
					>
						<path d="M0,20 Q80,-8 160,20" />
						<rect x="72" y="-4" width="8" height="8" transform="rotate(45 76 0)" />
						<rect x="72" y="-4" width="8" height="8" />
						<circle cx="76" cy="0" r="1.5" />
						<rect x="92" y="-4" width="8" height="8" transform="rotate(45 96 0)" opacity="0.6" />
						<rect x="92" y="-4" width="8" height="8" opacity="0.6" />
					</svg>
					<span class="h-px flex-1 bg-border/60"></span>
				</div>
				<div class="flex items-center gap-2">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="-16 -16 32 32"
						width="20"
						height="20"
						class="ornament-stroke animate-breathe"
						stroke-width="1"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect x="-10" y="-10" width="20" height="20" rx="1" />
						<rect x="-10" y="-10" width="20" height="20" rx="1" transform="rotate(45)" />
						<circle cx="0" cy="0" r="3" opacity="0.5" />
					</svg>
				</div>
			</div>
		) : variant === 'double' ? (
			<div class="flex w-full items-center gap-4">
				<span class="h-px flex-1 bg-border/60"></span>
				<div class="flex flex-col gap-2">
					<div class="flex items-center gap-2">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="-16 -16 32 32"
							width="20"
							height="20"
							class="ornament-stroke animate-breathe"
							stroke-width="1"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<rect x="-10" y="-10" width="20" height="20" rx="1" />
							<rect x="-10" y="-10" width="20" height="20" rx="1" transform="rotate(45)" />
							<circle cx="0" cy="0" r="3" opacity="0.5" />
						</svg>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="-4 -4 8 8"
							width="5"
							height="5"
							class="ornament-stroke"
							stroke-width="1"
						>
							<circle cx="0" cy="0" r="2" />
						</svg>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="-16 -16 32 32"
							width="20"
							height="20"
							class="ornament-stroke animate-breathe"
							stroke-width="1"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<rect x="-10" y="-10" width="20" height="20" rx="1" />
							<rect x="-10" y="-10" width="20" height="20" rx="1" transform="rotate(45)" />
							<circle cx="0" cy="0" r="3" opacity="0.5" />
						</svg>
					</div>
					<div class="flex items-center gap-2">
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="-16 -16 32 32"
							width="20"
							height="20"
							class="ornament-stroke animate-breathe"
							stroke-width="1"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<rect x="-10" y="-10" width="20" height="20" rx="1" />
							<rect x="-10" y="-10" width="20" height="20" rx="1" transform="rotate(45)" />
							<circle cx="0" cy="0" r="3" opacity="0.5" />
						</svg>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="-4 -4 8 8"
							width="5"
							height="5"
							class="ornament-stroke"
							stroke-width="1"
						>
							<circle cx="0" cy="0" r="2" />
						</svg>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="-16 -16 32 32"
							width="20"
							height="20"
							class="ornament-stroke animate-breathe"
							stroke-width="1"
							stroke-linecap="round"
							stroke-linejoin="round"
						>
							<rect x="-10" y="-10" width="20" height="20" rx="1" />
							<rect x="-10" y="-10" width="20" height="20" rx="1" transform="rotate(45)" />
							<circle cx="0" cy="0" r="3" opacity="0.5" />
						</svg>
					</div>
				</div>
				<span class="h-px flex-1 bg-border/60"></span>
			</div>
		) : (
			<div class="flex w-full items-center gap-4">
				<span class="h-px flex-1 bg-border/60"></span>
				<div class="flex items-center gap-2">
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="-16 -16 32 32"
						width="20"
						height="20"
						class="ornament-stroke animate-breathe"
						stroke-width="1"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect x="-10" y="-10" width="20" height="20" rx="1" />
						<rect x="-10" y="-10" width="20" height="20" rx="1" transform="rotate(45)" />
						<circle cx="0" cy="0" r="3" opacity="0.5" />
					</svg>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="-4 -4 8 8"
						width="5"
						height="5"
						class="ornament-stroke"
						stroke-width="1"
					>
						<circle cx="0" cy="0" r="2" />
					</svg>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="-16 -16 32 32"
						width="20"
						height="20"
						class="ornament-stroke animate-breathe"
						stroke-width="1"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect x="-10" y="-10" width="20" height="20" rx="1" />
						<rect x="-10" y="-10" width="20" height="20" rx="1" transform="rotate(45)" />
						<circle cx="0" cy="0" r="3" opacity="0.5" />
					</svg>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="-4 -4 8 8"
						width="5"
						height="5"
						class="ornament-stroke"
						stroke-width="1"
					>
						<circle cx="0" cy="0" r="2" />
					</svg>
					<svg
						xmlns="http://www.w3.org/2000/svg"
						viewBox="-16 -16 32 32"
						width="20"
						height="20"
						class="ornament-stroke animate-breathe"
						stroke-width="1"
						stroke-linecap="round"
						stroke-linejoin="round"
					>
						<rect x="-10" y="-10" width="20" height="20" rx="1" />
						<rect x="-10" y="-10" width="20" height="20" rx="1" transform="rotate(45)" />
						<circle cx="0" cy="0" r="3" opacity="0.5" />
					</svg>
				</div>
				<span class="h-px flex-1 bg-border/60"></span>
			</div>
		)
	}
</div>
