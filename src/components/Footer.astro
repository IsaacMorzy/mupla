---
import { tinaField } from '@tinacms/astro/tina-field';
import type { CmsConfig, CmsConfigContactLink } from '../lib/data';
import IconLink from './IconLink.astro';
import Input from './ui/Input.astro';
import Label from './ui/Label.astro';
import Button from './ui/Button.astro';
import IslamicDivider from './ui/IslamicDivider.astro';

interface Props {
	config?: CmsConfig | null;
}

const { config } = Astro.props;
const seo = config?.seo ?? null;
const contactLinks = (config?.contactLinks ?? []).filter(
	(item): item is CmsConfigContactLink => item !== null,
);
const today = new Date();
const newsletterId = `newsletter-${Math.random().toString(36).slice(2, 9)}`;
const newsletterAction = (import.meta.env.PUBLIC_NEWSLETTER_ACTION ?? '').toString().trim();
---

<footer class="border-t bg-background pt-16 pb-8 text-sm text-muted-foreground relative overflow-hidden">
	<div class="relative mx-auto flex max-w-6xl flex-col gap-12 px-6">
		<IslamicDivider variant="single" class="max-w-4xl mx-auto -mt-10 mb-2" />

		<!-- Top row: brand + newsletter -->
		<div class="grid gap-10 md:grid-cols-[1fr_1.2fr] md:gap-16">
			<div class="max-w-md">
				{seo?.logo && (
					<img src={seo.logo} alt={`${seo?.title ?? 'mupla'} logo`} class="mb-4 size-10" decoding="async" />
				)}
				<h2 class="text-base font-medium text-foreground">{seo?.title}</h2>
				<p class="mt-2">Get monthly updates on our programs, events, and impact - straight to your inbox.</p>
				<form
					id={newsletterId}
					class="mt-5 flex flex-col gap-2 sm:flex-row sm:items-end"
					data-newsletter
					data-action={newsletterAction}
					data-success="Thanks! Check your inbox to confirm your subscription."
					data-error="Something went wrong. Please try again or email us directly."
					novalidate
				>
					<div class="grid flex-1 gap-1.5">
						<Label for={`${newsletterId}-email`}>Email address</Label>
						<Input
							id={`${newsletterId}-email`}
							name="email"
							type="email"
							required
							placeholder="you@example.com"
							class="bg-background"
						/>
					<input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" class="sr-only" />
					</div>
					<Button type="submit" size="lg">
						Subscribe
					</Button>
				</form>
				<div data-newsletter-feedback hidden class="mt-3"></div>
			</div>

			<!-- Link columns: Explore, Get Involved, Learn -->
			<div class="grid grid-cols-3 gap-6">
				<div>
					<h3 class="text-sm font-medium text-foreground">Explore</h3>
					<ul class="mt-3 space-y-2">
						<li><a href="/" class="transition-colors hover:text-foreground">Home</a></li>
						<li><a href="/about" class="transition-colors hover:text-foreground">About</a></li>
						<li><a href="/programs" class="transition-colors hover:text-foreground">Programs</a></li>
						<li><a href="/events" class="transition-colors hover:text-foreground">Events</a></li>
						<li><a href="/blog" class="transition-colors hover:text-foreground">Blog</a></li>
						<li><a href="/quran" class="transition-colors hover:text-foreground">Quran</a></li>
					</ul>
				</div>
				<div>
					<h3 class="text-sm font-medium text-foreground">Get involved</h3>
					<ul class="mt-3 space-y-2">
						<li><a href="/donate" class="transition-colors hover:text-foreground">Donate</a></li>
						<li><a href="/get-involved" class="transition-colors hover:text-foreground">Volunteer</a></li>
						<li><a href="/contact" class="transition-colors hover:text-foreground">Contact</a></li>
						<li><a href="/team" class="transition-colors hover:text-foreground">Our team</a></li>
						<li><a href="/prayers" class="transition-colors hover:text-foreground">Prayer times</a></li>
					</ul>
				</div>
				<div>
					<h3 class="text-sm font-medium text-foreground">Learn</h3>
					<ul class="mt-3 space-y-2">
						<li><a href="/faq" class="transition-colors hover:text-foreground">FAQ</a></li>
						<li><a href="/privacy" class="transition-colors hover:text-foreground">Privacy</a></li>
						<li><a href="/terms" class="transition-colors hover:text-foreground">Terms</a></li>
					</ul>
					<h3 class="mt-6 text-sm font-medium text-foreground">Connect</h3>
					{contactLinks.length > 0 && (
						<div class="mt-3 flex flex-wrap gap-2">
							{contactLinks.map((link) => (
								<IconLink
									title={link.title}
									link={link.link}
									icon={link.icon}
									data-tina-field={tinaField(link, 'title')}
								/>
							))}
						</div>
					)}
				</div>
			</div>
		</div>

		<!-- Bottom bar: copyright + credit -->
		<div class="flex flex-col items-center gap-4 border-t pt-8 text-center sm:flex-row sm:justify-between sm:text-left">
			<p>
				&copy; {today.getFullYear()}
				<span data-tina-field={seo ? tinaField(seo, 'siteOwner') : undefined}>{seo?.siteOwner}</span>. All rights reserved.
			</p>
			<p class="text-xs text-muted-foreground/60">
				Built with care by the mupla community.
			</p>
		</div>
	</div>
</footer>

<script is:inline>
	document.querySelectorAll('form[data-newsletter]').forEach((form) => {
		if (form.dataset.bound) return;
		form.dataset.bound = '1';
		form.addEventListener('submit', (e) => {
			e.preventDefault();
			const data = new FormData(form);
			const email = (data.get('email') ?? '').toString().trim();
			const feedback = form.parentElement?.querySelector('[data-newsletter-feedback]');
			const showFeedback = (kind, body) => {
				if (!feedback) return;
				feedback.hidden = false;
				feedback.innerHTML = `
					<div role="alert" class="relative w-full rounded-lg border px-4 py-3 text-sm [&>svg+div]:translate-y-[-3px] [&>svg]:absolute [&>svg]:left-4 [&>svg]:top-4 [&>svg]:text-foreground [&>svg~*]:pl-7 ${kind === 'error' ? 'border-destructive/50 text-destructive bg-destructive/10' : 'bg-background text-foreground border-border'}">
						<div class="text-sm [&_p]:leading-relaxed"><p>${body}</p></div>
					</div>
				`;
			};
			if ((form.querySelector('[name="_gotcha"]')?.value || '').trim()) return;
			if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
				showFeedback('error', 'Please enter a valid email address.');
				return;
			}
			const action = form.dataset.action;
			if (action) {
				fetch(action, {
					method: 'POST',
					body: new FormData(form),
					headers: { 'Accept': 'application/json' },
				}).then((r) => {
					if (r.ok) {
						showFeedback('success', form.dataset.success || "Thanks! Check your inbox to confirm.");
						form.reset();
					} else {
						showFeedback('error', form.dataset.error || 'Please try again or email us directly.');
					}
				}).catch(() => {
					showFeedback('error', form.dataset.error || 'Please try again or email us directly.');
				});
				return;
			}
			const subject = encodeURIComponent('Newsletter subscription');
			const body = encodeURIComponent(`Please add ${email} to the mupla newsletter.`);
			window.location.href = `mailto:hello@mupla.org?subject=${subject}&body=${body}`;
			showFeedback('success', form.dataset.success || "Thanks! Check your inbox to confirm.");
			form.reset();
		});
	});
</script>
