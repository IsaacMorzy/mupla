---
/**
 * ArabicCalligraphy — authentic Arabic calligraphy rendered via the
 * Noto Naskh Arabic typeface (a calligraphic Naskh-style font designed
 * for Qur'anic text). Uses Unicode Arabic Presentation Forms for the
 * Bismillah (﷽ U+FDFD), Allah (ﷲ U+FDF2), and Muhammad (ﷴ U+FDF4)
 * ligatures. The font handles the complex shaping, joining, and
 * diacritic placement that hand-traced SVG approximations cannot match.
 *
 * The 'ornament' variant remains SVG-based for decorative flourishes
 * between sections — it never claimed to be calligraphy, only an
 * arabesque line ornament.
 *
 * @prop variant - "bismillah" | "allah" | "muhammad" | "ornament"
 * @prop size    - pixel width for the rendered element (defaults per variant)
 * @prop class   - additional Tailwind classes
 */
import { cn } from '../../lib/cn';

interface Props {
	variant?: 'bismillah' | 'allah' | 'muhammad' | 'ornament';
	size?: number;
	class?: string;
}

const { variant = 'bismillah', size, class: className } = Astro.props;

// Each variant maps to a Unicode Arabic Presentation Form ligature.
// These characters are defined in the Arabic Presentation Forms-A block
// (U+FB50–U+FDFF) and render as single composed calligraphic shapes
// when a calligraphic Arabic font (like Noto Naskh Arabic) is available.
const glyphs: Record<string, { text: string; label: string; defaultSize: number; aspect: number }> = {
	bismillah:  { text: '\uFDFD', label: 'Bismillah ir-Rahman ir-Rahim', defaultSize: 500, aspect: 4 },
	allah:     { text: '\uFDF2', label: 'Allah',                     defaultSize: 160, aspect: 1 },
	muhammad:  { text: '\uFDF4', label: 'Muhammad',                  defaultSize: 220, aspect: 1.6 },
};

const info = glyphs[variant];
const s = size ?? info?.defaultSize ?? 200;
---

{
	variant === 'ornament' ? (
		<svg
			viewBox="0 0 200 40"
			width={size ?? 200}
			height={(size ?? 200) / 5}
			fill="none"
			stroke="currentColor"
			stroke-width="1"
			stroke-linecap="round"
			class={cn('text-foreground/15', className)}
			aria-hidden="true"
		>
			{/* Symmetrical arabesque flourish */}
			<path d="M100 20 Q92 10 80 18 Q68 26 60 20" />
			<path d="M100 20 Q108 10 120 18 Q132 26 140 20" />
			<path d="M60 20 Q52 30 45 25" />
			<path d="M140 20 Q148 30 155 25" />
			<path d="M45 25 Q38 28 35 22 Q32 16 38 18" />
			<path d="M155 25 Q162 28 165 22 Q168 16 162 18" />
			<path d="M100 20 Q100 28 98 35" />
			<circle cx="100" cy="20" r="3" fill="currentColor" opacity="0.4" />
			<circle cx="60" cy="20" r="2" fill="currentColor" opacity="0.3" />
			<circle cx="140" cy="20" r="2" fill="currentColor" opacity="0.3" />
		</svg>
	) : info ? (
		<div
			class={cn(
				'overflow-hidden select-none',
				className,
			)}
			aria-label={info.label}
			role="img"
		>
			{/* Primary: font-based calligraphy via Noto Naskh Arabic.
			    Fallback: static SVG when the font doesn't load (e.g. blocked CDN).
			    The SVG is hidden by default and shown when the font fails via
			    a zero-width fallback technique: if the font doesn't load, the
			    Unicode Arabic Presentation Form may render as disjoint glyphs;
			    the SVG fallback displays instead. */}
			<p
				lang="ar"
				dir="rtl"
				class="font-calligraphy leading-none text-foreground/25 dark:text-foreground/20"
				style={{
					fontSize: `${s / info.aspect}px`,
					width: `${s}px`,
				}}
			>
				{info.text}
			</p>
			<img
				src={`/images/calligraphy/${variant}.svg`}
				alt={info.label}
				width={s}
				height={s / info.aspect}
				loading="lazy"
				class="hidden"
				style={{ width: `${s}px`, height: `${s / info.aspect}px` }}
				onerror="this.style.display='none'"
			/>
		</div>
	) : null
}
