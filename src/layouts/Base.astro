---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ArabicCalligraphy from '../components/ui/ArabicCalligraphy.astro';
import TinaIsland from '@tinacms/astro/TinaIsland.astro';
import { getConfig } from '../lib/data';
import { islands } from '../lib/islands';

interface Props {
	title: string;
	description: string;
	image?: string;
}

const { title, description, image } = Astro.props;
const config = (await getConfig()).data?.config ?? null;
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} image={image} />
	</head>
	<body>
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:z-[9999] focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground focus:outline-none">Skip to content</a>
		<TinaIsland name="global" wrapper={islands.global.wrapper}>
			<Header config={config} />
		</TinaIsland>
		<slot />
		<!-- Decorative Arabic calligraphy ornament between main content and footer -->
		<div class="mx-auto max-w-5xl px-6 overflow-hidden" aria-hidden="true">
			<ArabicCalligraphy variant="ornament" class="mx-auto block opacity-60" size={300} />
		</div>
		<TinaIsland name="global-footer" wrapper={islands['global-footer'].wrapper}>
			<Footer config={config} />
		</TinaIsland>

		<!--
		  Scroll-reveal observer. Lightweight, idempotent, gated by
		  prefers-reduced-motion (CSS side: any .reveal element is rendered
		  fully opaque when reduced-motion is requested, see global.css).
		  We pick elements up after idle timers because Block island
		  replacements can inject new nodes after the initial observer
		  boot, so a single mount-time sweep would miss late additions.
		-->
		<script>
			const w = window as Window & { __muplaRevealBound?: boolean };
			if (!w.__muplaRevealBound) {
				w.__muplaRevealBound = true;
				const init = () => {
					const els = document.querySelectorAll<HTMLElement>('.reveal:not([data-revealed="true"])');
					if (els.length === 0) return;
					const observer = new IntersectionObserver(
						(entries) => {
							for (const entry of entries) {
								if (entry.isIntersecting) {
									entry.target.setAttribute('data-revealed', 'true');
									observer.unobserve(entry.target);
								}
							}
						},
						{ threshold: 0.05, rootMargin: '0px 0px -40px 0px' },
					);
					els.forEach((el) => observer.observe(el));
				};
				// Boot after layout settles. The Tina island reconciler can
				// mount blocks lazily on slow connections; we re-run the
				// observer on a short debounced timer so late-mounted .reveal
				// nodes are still picked up.
				if (document.readyState === 'complete') init();
				else window.addEventListener('load', init, { once: true });
				let debounce: ReturnType<typeof setTimeout> | null = null;
				const reobserve = () => {
					if (debounce) clearTimeout(debounce);
					debounce = setTimeout(init, 250);
				};
				document.addEventListener('astro:page-load', reobserve);
			}
		</script>
	</body>
</html>
